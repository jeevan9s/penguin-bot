	(text "Vout < 2.8V (S3 Docs)\n\nVout = Vbatt * (R2) / (R1+R2)\nR1 = 100k \n\nR2 = (R1 * Vout) / (Vbatt - Vout)\nR2 = (100000 * 2.8) / (7.4 - 2.8) = 50k ≈ 47k"
		(exclude_from_sim no)
		(at 71.12 351.79 0)
		(effects
			(font
